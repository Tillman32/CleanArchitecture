@page "/"
@using CleanArchitecture.Core.Service
@using CleanArchitecture.Core.Data.DTO
@inject IArticleService ArticleService

<PageTitle>Bob Ross Blog</PageTitle>

<div class="hero">
    <div class="hero-inner">
        <div class="hero-eyebrow">A Celebration of Joy &amp; Painting</div>
        <h1 class="hero-title">The World of Bob Ross</h1>
        <p class="hero-subtitle">
            Exploring the techniques, philosophy, and timeless beauty of America's most beloved painter &mdash;
            one happy little post at a time.
        </p>
        <div class="hero-actions">
            <a href="posts" class="btn-hero-primary">Browse All Posts</a>
            <a href="new-post" class="btn-hero-outline">Write a Post</a>
        </div>
    </div>
</div>

<div class="content-area">

    @if (featured != null)
    {
        <div class="section-header">
            <h2 class="section-title">Featured Post</h2>
        </div>
        <div class="featured-card">
            <div class="featured-image">@GetEmoji(featured.Category?.Title)</div>
            <div class="featured-body">
                <span class="featured-badge">Featured</span>
                <h3 class="featured-title">@featured.Title</h3>
                <p class="featured-excerpt">@featured.ContentPreview</p>
                <div class="post-meta">
                    <span class="meta-date">@featured.DateCreated.ToString("MMMM d, yyyy")</span>
                    <a href="posts/@featured.Id" class="btn-read">Read Post &rarr;</a>
                </div>
            </div>
        </div>
    }

    @if (latestPosts.Count > 0)
    {
        <div class="section-header">
            <h2 class="section-title">Latest Posts</h2>
            <a href="posts" class="section-link">View all &rarr;</a>
        </div>
        <div class="post-grid">
            @foreach (var post in latestPosts)
            {
                <div class="post-card">
                    <div class="card-image @GetCardClass(post.Category?.Title)">@GetEmoji(post.Category?.Title)</div>
                    <div class="card-body">
                        <div class="card-category">@(post.Category?.Title ?? "Other")</div>
                        <h4 class="card-title">@post.Title</h4>
                        <p class="card-excerpt">@post.ContentPreview</p>
                        <div class="card-footer">
                            <span class="meta-date">@post.DateCreated.ToString("MMMM d, yyyy")</span>
                            <a href="posts/@post.Id" class="link-read">Read &rarr;</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>

@code {
    private ArticleDTO? featured;
    private List<ArticleDTO> latestPosts = new();

    protected override async Task OnInitializedAsync()
    {
        var all = (await ArticleService.ListAllArticlesAsync())?.ToList() ?? new();
        featured = all.FirstOrDefault();
        latestPosts = all.Skip(1).Take(3).ToList();
    }

    private string GetEmoji(string? category) => category switch
    {
        "Mountains"   => "🏔️",
        "Technique"   => "🌲",
        "Waterscapes" => "🌊",
        "Seasons"     => "🍂",
        "Nature"      => "🌸",
        _             => "🎨"
    };

    private string GetCardClass(string? category) => category switch
    {
        "Mountains"   => "card-mountains",
        "Technique"   => "card-trees",
        "Waterscapes" => "card-water",
        "Seasons"     => "card-mountains",
        "Nature"      => "card-trees",
        _             => "card-mountains"
    };
}
