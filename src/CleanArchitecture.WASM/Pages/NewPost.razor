@page "/new-post"
@using CleanArchitecture.Core.Service
@using CleanArchitecture.Core.Data.DTO
@inject IArticleService ArticleService
@inject IArticleCategoryService CategoryService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@(post.Id > 0 ? "Edit Draft" : "New Post")</PageTitle>

@if (published)
{
    <div class="success-banner">
        <span>🎨 Post published! Your happy little post is live.</span>
        <button class="dismiss-btn" @onclick="() => published = false">✕</button>
    </div>
}

@if (draftSaved)
{
    <div class="draft-banner">
        <span>Draft saved.</span>
        <button class="dismiss-btn" @onclick="() => draftSaved = false">✕</button>
    </div>
}

@if (!string.IsNullOrEmpty(error))
{
    <div class="error-banner">
        <span>@error</span>
        <button class="dismiss-btn" @onclick="() => error = null">✕</button>
    </div>
}

<EditForm EditContext="_editContext" OnValidSubmit="PublishPost">
    <DataAnnotationsValidator />

    <div class="editor-layout">
        <!-- Left: Editor Form -->
        <div class="editor-main">
            <div class="editor-header">
                <h1 class="page-heading">@(post.Id > 0 ? "Edit Draft" : "New Post")</h1>
                @if (post.Id > 0)
                {
                    <button type="button" class="btn-new" @onclick="StartNewPost">+ New Post</button>
                }
            </div>

            <div class="form-group">
                <input class="title-input"
                       type="text"
                       placeholder="Post title..."
                       @bind="post.Title"
                       @bind:event="oninput" />
                <ValidationMessage For="() => post.Title" class="field-error" />
            </div>

            <div class="form-group">
                <select class="category-select" @bind="post.CategoryId">
                    @foreach (var cat in categories)
                    {
                        <option value="@cat.Id">@cat.Title</option>
                    }
                </select>
            </div>

            <div class="toolbar">
                <button type="button" class="toolbar-btn toolbar-bold" @onclick='() => ApplyFormat("bold")'>B</button>
                <button type="button" class="toolbar-btn toolbar-italic" @onclick='() => ApplyFormat("italic")'>I</button>
                <button type="button" class="toolbar-btn" @onclick='() => ApplyFormat("h2")'>H2</button>
                <button type="button" class="toolbar-btn" @onclick='() => ApplyFormat("h3")'>H3</button>
                <button type="button" class="toolbar-btn" @onclick='() => ApplyFormat("quote")'>❝</button>
                <button type="button" class="toolbar-btn" @onclick='() => ApplyFormat("link")'>🔗</button>
                <button type="button" class="toolbar-btn" @onclick='() => ApplyFormat("image")'>🖼</button>
            </div>

            <div class="form-group">
                <textarea class="content-textarea"
                          placeholder="Write your post here... every painting starts with a single brushstroke."
                          @bind="post.Content"
                          @bind:event="oninput"
                          @ref="_contentTextarea"></textarea>
                <ValidationMessage For="() => post.Content" class="field-error" />
                <span class="char-count @(post.Content?.Length > 950 ? "char-count--warn" : "")">
                    @(post.Content?.Length ?? 0) / 1000
                </span>
            </div>
        </div>

        <!-- Right: Publish Sidebar -->
        <aside class="publish-sidebar">
            <div class="sidebar-card">
                <p class="sidebar-section-label">Publish</p>

                <div class="status-row">
                    <span class="status-label">Status:</span>
                    <span class="status-badge">@(post.Id > 0 ? "Draft" : "New")</span>
                </div>

                <button type="submit" class="btn-publish" disabled="@saving">
                    @(saving ? "Publishing..." : "Publish Now")
                </button>

                <hr class="divider" />

                <button type="button" class="btn-draft" @onclick="SaveDraft" disabled="@saving">
                    @(saving ? "Saving..." : "Save Draft")
                </button>

                <hr class="divider" />

                <p class="sidebar-section-label">Post Settings</p>

                <div class="form-group">
                    <input class="tags-input"
                           type="text"
                           placeholder="Add tags (comma separated)..."
                           @bind="post.Tags"
                           @bind:event="oninput" />
                </div>
            </div>

            @if (drafts.Count > 0)
            {
                <div class="sidebar-card drafts-card">
                    <p class="sidebar-section-label">Your Drafts</p>
                    @foreach (var draft in drafts)
                    {
                        <div class="draft-item @(post.Id == draft.Id ? "draft-item-active" : "")">
                            <div class="draft-info">
                                <span class="draft-title">@(string.IsNullOrWhiteSpace(draft.Title) ? "Untitled" : draft.Title)</span>
                                <span class="draft-date">@draft.DateCreated.ToString("MMM d")</span>
                            </div>
                            <div class="draft-actions">
                                <button type="button" class="btn-load-draft" @onclick="() => LoadDraft(draft)">
                                    Resume
                                </button>
                                <button type="button" class="btn-delete-draft" @onclick="() => DeleteDraft(draft.Id)">
                                    ✕
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        </aside>
    </div>
</EditForm>

@code {
    private ArticleDTO post = new() { Tags = "" };
    private EditContext _editContext = null!;
    private List<ArticleCategoryDTO> categories = new();
    private List<ArticleDTO> drafts = new();
    private bool published;
    private bool draftSaved;
    private bool saving;
    private string? error;
    private ElementReference _contentTextarea;

    private async Task ApplyFormat(string format)
    {
        var newValue = await JS.InvokeAsync<string>("editorInsertFormat", _contentTextarea, format);
        post.Content = newValue;
    }

    protected override void OnInitialized()
    {
        _editContext = new EditContext(post);
    }

    protected override async Task OnInitializedAsync()
    {
        var cats = await CategoryService.ListAllArticleCategoriesAsync();
        categories = cats?.ToList() ?? new();
        if (categories.Count > 0)
            post.CategoryId = categories[0].Id;
        await LoadDrafts();
    }

    private async Task LoadDrafts()
    {
        var d = await ArticleService.ListDraftsAsync();
        drafts = d?.ToList() ?? new();
    }

    private void LoadDraft(ArticleDTO draft)
    {
        post = draft;
        _editContext = new EditContext(post);
        published = false;
        draftSaved = false;
        error = null;
    }

    private async Task DeleteDraft(int id)
    {
        await ArticleService.DeleteArticleAsync(id);
        if (post.Id == id)
            StartNewPost();
        await LoadDrafts();
    }

    private void StartNewPost()
    {
        post = new ArticleDTO { Tags = "" };
        if (categories.Count > 0)
            post.CategoryId = categories[0].Id;
        _editContext = new EditContext(post);
        published = false;
        draftSaved = false;
        error = null;
    }

    private async Task PublishPost()
    {
        await DoSave(publish: true);
    }

    private async Task SaveDraft()
    {
        if (string.IsNullOrWhiteSpace(post.Title))
        {
            _editContext.Validate();
            return;
        }
        await DoSave(publish: false);
    }

    private async Task DoSave(bool publish)
    {
        saving = true;
        error = null;
        published = false;
        draftSaved = false;

        try
        {
            post.IsDraft = !publish;

            if (post.Id > 0)
                await ArticleService.UpdateArticleAsync(post);
            else
                await ArticleService.CreateArticleAsync(post);

            if (publish) published = true;
            else draftSaved = true;

            if (publish)
            {
                post = new ArticleDTO { Tags = "" };
                if (categories.Count > 0)
                    post.CategoryId = categories[0].Id;
                _editContext = new EditContext(post);
            }

            await LoadDrafts();
        }
        catch (Exception ex)
        {
            error = $"Failed to save: {ex.Message}";
        }
        finally
        {
            saving = false;
        }
    }
}
