@page "/new-post"
@using CleanArchitecture.Core.Service
@using CleanArchitecture.Core.Data.DTO
@inject IArticleService ArticleService
@inject IArticleCategoryService CategoryService
@inject NavigationManager Nav

<PageTitle>New Post</PageTitle>

@if (published)
{
    <div class="success-banner">
        <span>🎨 Post published! Your happy little post is live.</span>
        <button class="dismiss-btn" @onclick="() => published = false">✕</button>
    </div>
}

@if (!string.IsNullOrEmpty(error))
{
    <div class="error-banner">
        <span>@error</span>
        <button class="dismiss-btn" @onclick="() => error = null">✕</button>
    </div>
}

<div class="editor-layout">
    <!-- Left: Editor Form -->
    <div class="editor-main">
        <h1 class="page-heading">New Post</h1>

        <div class="form-group">
            <input class="title-input"
                   type="text"
                   placeholder="Post title..."
                   @bind="post.Title"
                   @bind:event="oninput" />
        </div>

        <div class="form-group">
            <select class="category-select" @bind="post.CategoryId">
                @foreach (var cat in categories)
                {
                    <option value="@cat.Id">@cat.Title</option>
                }
            </select>
        </div>

        <div class="toolbar">
            <button type="button" class="toolbar-btn toolbar-bold">B</button>
            <button type="button" class="toolbar-btn toolbar-italic">I</button>
            <button type="button" class="toolbar-btn">H2</button>
            <button type="button" class="toolbar-btn">H3</button>
            <button type="button" class="toolbar-btn">❝</button>
            <button type="button" class="toolbar-btn">🔗</button>
            <button type="button" class="toolbar-btn">🖼</button>
        </div>

        <div class="form-group">
            <textarea class="content-textarea"
                      placeholder="Write your post here... every painting starts with a single brushstroke."
                      @bind="post.Content"
                      @bind:event="oninput"></textarea>
        </div>
    </div>

    <!-- Right: Publish Sidebar -->
    <aside class="publish-sidebar">
        <div class="sidebar-card">
            <p class="sidebar-section-label">Publish</p>

            <div class="status-row">
                <span class="status-label">Status:</span>
                <span class="status-badge">Draft</span>
            </div>

            <button class="btn-publish" @onclick="PublishPost" disabled="@saving">
                @(saving ? "Publishing..." : "Publish Now")
            </button>

            <hr class="divider" />

            <button class="btn-draft">Save Draft</button>

            <hr class="divider" />

            <p class="sidebar-section-label">Post Settings</p>

            <div class="form-group">
                <input class="tags-input"
                       type="text"
                       placeholder="Add tags (comma separated)..."
                       @bind="post.Tags"
                       @bind:event="oninput" />
            </div>
        </div>
    </aside>
</div>

@code {
    private ArticleDTO post = new() { Tags = "" };
    private List<ArticleCategoryDTO> categories = new();
    private bool published;
    private bool saving;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        var cats = await CategoryService.ListAllArticleCategoriesAsync();
        categories = cats?.ToList() ?? new();
        if (categories.Count > 0)
            post.CategoryId = categories[0].Id;
    }

    private async Task PublishPost()
    {
        if (string.IsNullOrWhiteSpace(post.Title))
        {
            error = "Title is required.";
            return;
        }

        saving = true;
        error = null;

        try
        {
            await ArticleService.CreateArticleAsync(post);
            published = true;
            post = new ArticleDTO { Tags = "" };
            if (categories.Count > 0)
                post.CategoryId = categories[0].Id;
        }
        catch (Exception ex)
        {
            error = $"Failed to publish: {ex.Message}";
        }
        finally
        {
            saving = false;
        }
    }
}
