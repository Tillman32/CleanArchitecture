@inherits LayoutComponentBase

<div class="flex flex-col min-h-screen bg-gray-50">
    <!-- Top Navigation Bar -->
    <nav class="bg-white shadow-sm border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <div class="flex items-center space-x-8">
                    <a href="/" class="font-bold text-xl text-gray-900 hover:text-blue-600 transition-colors">
                        CleanArchitecture
                    </a>
                    <NavMenu />
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content Area -->
    <div class="flex-1">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <!-- Main Content -->
                <main class="lg:col-span-2">
                    <article class="bg-white rounded-lg shadow-md p-8">
                        @Body
                    </article>
                </main>

                <!-- Sidebar Widget Area -->
                <aside class="lg:col-span-1">
                    <!-- Featured Posts Widget -->
                    <div class="bg-white rounded-lg shadow-md p-6 mb-6">
                        <h3 class="text-lg font-bold text-gray-900 mb-4 pb-3 border-b border-gray-200">
                            Featured Posts
                        </h3>
                        <div class="space-y-4">
                            <div class="pb-4 border-b border-gray-100 last:border-b-0 last:pb-0">
                                <a href="#" class="text-blue-600 hover:text-blue-800 font-semibold block mb-1 transition-colors">
                                    Getting Started with Blazor
                                </a>
                                <p class="text-sm text-gray-500">Learn the basics...</p>
                            </div>
                            <div class="pb-4 border-b border-gray-100 last:border-b-0 last:pb-0">
                                <a href="#" class="text-blue-600 hover:text-blue-800 font-semibold block mb-1 transition-colors">
                                    Clean Architecture Patterns
                                </a>
                                <p class="text-sm text-gray-500">Best practices guide...</p>
                            </div>
                            <div class="pb-4 border-b border-gray-100 last:border-b-0 last:pb-0">
                                <a href="#" class="text-blue-600 hover:text-blue-800 font-semibold block mb-1 transition-colors">
                                    Tailwind CSS Tips
                                </a>
                                <p class="text-sm text-gray-500">Utility-first design...</p>
                            </div>
                        </div>
                    </div>

                    <!-- Categories Widget -->
                    <div class="bg-white rounded-lg shadow-md p-6 mb-6">
                        <h3 class="text-lg font-bold text-gray-900 mb-4 pb-3 border-b border-gray-200">
                            Categories
                        </h3>
                        <ul class="space-y-2">
                            <li>
                                <a href="#" class="text-blue-600 hover:text-blue-800 flex items-center justify-between transition-colors">
                                    <span>Development</span>
                                    <span class="text-sm text-gray-500 bg-gray-100 px-2 py-1 rounded">12</span>
                                </a>
                            </li>
                            <li>
                                <a href="#" class="text-blue-600 hover:text-blue-800 flex items-center justify-between transition-colors">
                                    <span>Design</span>
                                    <span class="text-sm text-gray-500 bg-gray-100 px-2 py-1 rounded">8</span>
                                </a>
                            </li>
                            <li>
                                <a href="#" class="text-blue-600 hover:text-blue-800 flex items-center justify-between transition-colors">
                                    <span>Tutorial</span>
                                    <span class="text-sm text-gray-500 bg-gray-100 px-2 py-1 rounded">5</span>
                                </a>
                            </li>
                        </ul>
                    </div>

                    <!-- About Widget -->
                    <div class="bg-blue-50 rounded-lg shadow-md p-6 border border-blue-200">
                        <h3 class="text-lg font-bold text-gray-900 mb-3">
                            About This Blog
                        </h3>
                        <p class="text-sm text-gray-700 leading-relaxed">
                            Welcome to our blog covering web development, clean architecture, and modern design patterns. Subscribe to stay updated.
                        </p>
                    </div>
                </aside>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-100 mt-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <div class="text-center text-sm">
                <p>&copy; 2025 CleanArchitecture. All rights reserved.</p>
            </div>
        </div>
    </footer>
</div>

<div id="blazor-error-ui" data-nosnippet class="hidden fixed bottom-0 left-0 right-0 bg-red-600 text-white p-4 shadow-lg z-50">
    An unhandled error has occurred.
    <a href="." class="underline ml-2">Reload</a>
    <span class="ml-4 cursor-pointer">🗙</span>
</div>
