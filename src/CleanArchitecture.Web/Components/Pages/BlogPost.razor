@page "/blog/{slug}"

<!-- Blog Post Header -->
<div class="mb-8 pb-8 border-b border-gray-200">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">@PostTitle</h1>
    
    <div class="flex items-center space-x-6 text-gray-500 mb-6">
        <div class="flex items-center space-x-2">
            <div class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center text-white font-bold">
                A
            </div>
            <div>
                <p class="font-semibold text-gray-900">Author Name</p>
                <p class="text-sm">November 23, 2025</p>
            </div>
        </div>
        <div class="text-right">
            <p class="text-sm font-medium">8 min read</p>
        </div>
    </div>

    <div class="flex flex-wrap gap-2">
        <span class="inline-block bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm font-medium">Development</span>
        <span class="inline-block bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Tutorial</span>
    </div>
</div>

<!-- Blog Post Content -->
<div class="prose max-w-none mb-8">
    <p class="text-lg text-gray-600 mb-6">
        This is the introduction paragraph of your blog post. It should provide context and set expectations for what the reader will learn.
    </p>

    <h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Section One</h2>
    <p class="text-gray-700 mb-4">
        This is your main content. You can add as much text as you need here to explain your topic in detail.
    </p>

    <h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Section Two</h2>
    <p class="text-gray-700 mb-4">
        Continue with more sections as needed. The layout will automatically adapt to your content.
    </p>

    <h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Conclusion</h2>
    <p class="text-gray-700 mb-4">
        Wrap up your post with a summary and call to action for your readers.
    </p>
</div>

<!-- Author Bio -->
<div class="bg-gray-50 rounded-lg p-6 my-8 border border-gray-200">
    <div class="flex items-start space-x-4">
        <div class="w-16 h-16 bg-blue-600 rounded-full flex-shrink-0 flex items-center justify-center text-white text-2xl font-bold">
            A
        </div>
        <div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Author Name</h3>
            <p class="text-gray-600 text-sm">
                This is a brief bio about the author. Include their expertise, experience, and link to their website or social profiles.
            </p>
        </div>
    </div>
</div>

<!-- Related Posts -->
<div class="my-12 pt-8 border-t border-gray-200">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Related Posts</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <article class="bg-gray-50 rounded-lg p-6 hover:shadow-md transition-shadow">
            <h3 class="text-lg font-bold text-gray-900 mb-2">
                <a href="/blog/related-post-1" class="text-blue-600 hover:text-blue-800">Related Post One</a>
            </h3>
            <p class="text-gray-600 text-sm mb-3">A brief description of the related post goes here...</p>
            <a href="/blog/related-post-1" class="text-blue-600 hover:text-blue-800 font-medium text-sm">Read More →</a>
        </article>

        <article class="bg-gray-50 rounded-lg p-6 hover:shadow-md transition-shadow">
            <h3 class="text-lg font-bold text-gray-900 mb-2">
                <a href="/blog/related-post-2" class="text-blue-600 hover:text-blue-800">Related Post Two</a>
            </h3>
            <p class="text-gray-600 text-sm mb-3">A brief description of the related post goes here...</p>
            <a href="/blog/related-post-2" class="text-blue-600 hover:text-blue-800 font-medium text-sm">Read More →</a>
        </article>
    </div>
</div>

<!-- Comments Section -->
<div class="mt-12 pt-8 border-t border-gray-200">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Comments</h2>
    
    <!-- Comment Form -->
    <div class="bg-gray-50 rounded-lg p-6 mb-8">
        <h3 class="text-lg font-bold text-gray-900 mb-4">Leave a Comment</h3>
        <form class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                <input type="text" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input type="email" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Comment</label>
                <textarea rows="4" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"></textarea>
            </div>
            <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition-colors font-medium">
                Post Comment
            </button>
        </form>
    </div>

    <!-- Existing Comments -->
    <div class="space-y-6">
        <div class="pb-6 border-b border-gray-200">
            <div class="flex items-start space-x-4">
                <div class="w-10 h-10 bg-gray-300 rounded-full flex-shrink-0"></div>
                <div class="flex-1">
                    <h4 class="font-bold text-gray-900">John Doe</h4>
                    <p class="text-sm text-gray-500">November 23, 2025</p>
                    <p class="text-gray-700 mt-2">Great post! This really helped me understand the concepts better.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Slug { get; set; }

    private string PostTitle = "Getting Started with Blazor";
}
